# ============================================================================
# Sokogate Web — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env files to version control!
# ============================================================================

# ---- Application ----
NODE_ENV=development
VUE_APP_TITLE=Sokogate

# ---- Vue.js URLs ----
VUE_APP_V2_HOMEPAGE_URL=https://sokogate.com
VUE_APP_V1_HOMEPAGE_URL=https://sokogate.com

# ---- API URLs ----
VUE_APP_V2_API_URL=https://sokogate.cn/api/v2/
VUE_APP_API_URL=https://sokogate.cn/api/

# ---- Payment Gateways (placeholder — replace with your actual keys) ----
# ⚠️ Name must match src/main.js: process.env.VUE_APP_FLUTTERWAVE_PUBLIC_KEY
VUE_APP_FLUTTERWAVE_PUBLIC_KEY=CHANGE_ME_flutterwave_public_key

# Paystack inline checkout — used by src/components/payment/Paystack.vue
VUE_APP_V2_PAYSTACK_PUBLICKEY=CHANGE_ME_paystack_public_key

# ---- OSS (Alibaba Cloud Object Storage) ----
VUE_APP_OSS_REGION=oss-cn-hongkong
VUE_APP_OSS_BUCKET=sokogate-com
VUE_APP_OSS_ENDPOINT=https://oss-sokogate-com.oss-cn-hongkong.aliyuncs.com

# ---- Backend (used by docker-compose / deployment) ----
# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sokogate
DB_USER=sokogate
DB_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# JWT
JWT_SECRET=changeme-to-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Payment Gateway Secrets (placeholder — replace with your actual keys)
FLUTTERWAVE_SECRET_KEY=CHANGE_ME_flutterwave_secret
PAYSTACK_SECRET_KEY=CHANGE_ME_paystack_secret
STRIPE_SECRET_KEY=CHANGE_ME_stripe_secret

# OSS credentials (keep secure!)
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# Easemob (WebIM Chat)
EASEMOB_APPKEY=1101220606096669#demo
EASEMOB_CLIENT_ID=your-client-id
EASEMOB_CLIENT_SECRET=your-client-secret

# Google Analytics
VUE_APP_GA_MEASUREMENT_ID=G-3N56WXZDE0

# Sentry Error Tracking
VUE_APP_SENTRY_DSN=https://your-dsn@sentry.io/your-project
SENTRY_DSN=https://your-dsn@sentry.io/your-project

# SMTP / Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key

# ---- AI Engines (Comment Agent) ----
# At least ONE of these is required for the comment agent to work.
# AI_ENGINE controls which engine is primary: 'nvidia' (default) or 'claude'.
# The other engine is used as fallback if the primary fails.
AI_ENGINE=nvidia
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-sonnet-4-6

# Comment Agent daily capacity per agent
COMMENT_AGENT_DAILY_LIMIT=25
COMMENT_AGENT_MIN_DELAY=180
COMMENT_AGENT_MAX_DELAY=480

# Apify (social media scraping — optional but recommended)
APIFY_API_KEY=your-apify-api-key
APIFY_FACEBOOK_ACTOR=apify/facebook-posts-scraper
APIFY_LINKEDIN_ACTOR=curiosum/linkedin-post-scraper

# Email (SendGrid — required for sourcing alert emails from the Comment Agent)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=agent@sokogate.com

# SMTP fallback (used if SendGrid is not configured)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key

# Sourcing alert destination — the email address that receives Comment Agent
# sourcing alerts when a product is not found in the catalog.
# Defaults to info@sokogate.com if not set.
SOURCING_ALERT_EMAIL=info@sokogate.com

# pgvector extension required in PostgreSQL for semantic product matching
# Run: CREATE EXTENSION IF NOT EXISTS vector;

# ---- Google OAuth SSO (backend verifies — server-side only) ----
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ---- Google OAuth SSO (frontend — VUE_APP_ prefix makes it public in the bundle) ----
VUE_APP_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ---- Alibaba Cloud (for auto-scaling, ALB, etc.) ----
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret

