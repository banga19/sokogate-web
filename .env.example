# ============================================================================
# Sokogate Web — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env files to version control!
# ============================================================================

# ---- Application ----
NODE_ENV=development
VUE_APP_TITLE=Sokogate

# ---- Vue.js URLs ----
VUE_APP_V2_HOMEPAGE_URL=https://sokogate.com
VUE_APP_V1_HOMEPAGE_URL=https://sokogate.com

# ---- API URLs ----
VUE_APP_V2_API_URL=https://sokogate.cn/api/v2/
VUE_APP_API_URL=https://sokogate.cn/api/

# ---- Payment Gateways (placeholder — replace with your actual keys) ----
VUE_APP_V2_FLUTTERWAVE_PUBLICKEY=CHANGE_ME_flutterwave_public_key
VUE_APP_V2_PAYSTACK_PUBLICKEY=CHANGE_ME_paystack_public_key
VUE_APP_V2_STRIPE_PUBLICKEY=CHANGE_ME_stripe_public_key

# ---- OSS (Alibaba Cloud Object Storage) ----
VUE_APP_OSS_REGION=oss-cn-hongkong
VUE_APP_OSS_BUCKET=sokogate-com
VUE_APP_OSS_ENDPOINT=https://oss-sokogate-com.oss-cn-hongkong.aliyuncs.com

# ---- Backend (used by docker-compose / deployment) ----
# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sokogate
DB_USER=sokogate
DB_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# JWT
JWT_SECRET=changeme-to-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Payment Gateway Secrets (placeholder — replace with your actual keys)
FLUTTERWAVE_SECRET_KEY=CHANGE_ME_flutterwave_secret
PAYSTACK_SECRET_KEY=CHANGE_ME_paystack_secret
STRIPE_SECRET_KEY=CHANGE_ME_stripe_secret

# OSS credentials (keep secure!)
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# Easemob (WebIM Chat)
EASEMOB_APPKEY=1101220606096669#demo
EASEMOB_CLIENT_ID=your-client-id
EASEMOB_CLIENT_SECRET=your-client-secret

# Google Analytics
VUE_APP_GA_MEASUREMENT_ID=G-3N56WXZDE0

# Sentry Error Tracking
VUE_APP_SENTRY_DSN=https://your-dsn@sentry.io/your-project
SENTRY_DSN=https://your-dsn@sentry.io/your-project

# SMTP / Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key

# Alibaba Cloud (for auto-scaling, ALB, etc.)
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
