{
  "name": "sokogate-web",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "build": "node scripts/generate-sitemap.js && vue-cli-service build",
    "lint": "vue-cli-service lint",
    "build:test": "vue-cli-service build --mode test",
    "start": "vue-cli-service serve --port 4500 --watch",
    "sync:prod": "yarn build && ~/ossutilmac64 cp -r ./dist/ oss://www-sokogate-com/ -u",
    "sync:test": "yarn build:test && ~/ossutilmac64 cp -r ./test/ oss://www-sokogate-test/ -u",
