{
  "name": "sokogate-web",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "build": "node scripts/generate-sitemap.js && vue-cli-service build",
    "lint": "vue-cli-service lint",
    "build:test": "vue-cli-service build --mode test",
    "start": "vue-cli-service serve --port 4500 --watch",
    "sync:prod": "yarn build && ~/ossutilmac64 cp -r ./dist/ oss://www-sokogate-com/ -u",
    "sync:test": "yarn build:test && ~/ossutilmac64 cp -r ./test/ oss://www-sokogate-test/ -u",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "test:e2e:visual": "npx playwright test tests/e2e/store-visual.spec.js --config=tests/e2e/playwright.config.js --project=chromium",
    "test:e2e:visual:update": "npx playwright test tests/e2e/store-visual.spec.js --config=tests/e2e/playwright.config.js --project=chromium --update-snapshots",
    "test:e2e:badge": "npx playwright test tests/e2e/store-banner.spec.js --config=tests/e2e/playwright.config.js --project=chromium",
    "test:e2e:all": "npx playwright test tests/e2e/ --config=tests/e2e/playwright.config.js --project=chromium"
  },
  "dependencies": {
    "@paystack/inline-js": "^2.12.6",
    "@vue-stripe/vue-stripe": "^4.4.4",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.5.0",
    "better-scroll": "^2.5.1",
    "bootstrap": "^5.3.0",
    "bootstrap-vue": "^1.5.1",
    "caniuse-lite": "^1.0.30001797",
    "core-js": "^3.49.0",
    "cross-env": "^7.0.3",
    "crypto-js": "^4.1.1",
    "easemob-websdk": "^4.2.1",
    "element-ui": "^2.15.14",
    "flutterwave-vue-v3": "^1.0.9",
    "google-libphonenumber": "^3.2.27",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "moment": "^2.29.4",
    "qrcodejs2": "^0.0.2",
    "v-distpicker": "^2.1.0",
    "vue": "^2.7.16",
    "vue-cropper": "^0.5.8",
    "vue-i18n": "^8.28.2",
    "vue-jsonp": "^2.0.0",
    "vue-klasha": "^0.0.5",
    "vue-meta": "^2.4.0",
    "vue-owl-carousel": "^2.0.3",
    "vue-paypal-checkout": "^3.2.0",
    "vue-router": "^3.6.5",
    "vue-stripe": "^2.4.0",
    "vue-uweb": "^0.2.2",
    "vuejs-picture-zoom": "^1.0.0",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.29.7",
    "@playwright/test": "^1.61.0",
    "@sentry/vue": "^10.57.0",
    "@vue/cli-plugin-babel": "^5.0.9",
    "@vue/cli-plugin-eslint": "^5.0.9",
    "@vue/cli-service": "^5.0.8",
    "@vue/test-utils": "^1.3.6",
    "@vue/vue2-jest": "^29.2.6",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^29.7.0",
    "baseline-browser-mapping": "^2.10.34",
    "cache-loader": "^4.1.0",
    "compression-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "eslint-scope": "^7.2.2",
    "file-loader": "^6.2.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.0",
    "postcss-preset-env": "^10.4.0",
    "postcss-url": "^10.1.3",
    "sass": "1.70.0",
    "sass-loader": "14.0.0",
    "sitemap-webpack-plugin": "^1.1.1",
    "style-loader": "^4.0.0",
    "url-loader": "^4.1.1",
    "vue-template-compiler": "^2.7.16"
  },
  "resolutions": {
    "**/node-sass": "npm:sass@^1.70.0"
  },
  "overrides": {
    "node-sass": "npm:sass@^1.70.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser",
      "ecmaVersion": 2020,
      "sourceType": "module"
    },
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "allowScripts": {
    "vue-demi@0.14.10": true,
    "bootstrap-vue@1.5.1": true,
    "yorkie@2.0.0": true,
    "core-js@2.6.12": true,
    "core-js@3.49.0": true,
    "@parcel/watcher@2.5.6": true,
    "eslint-visitor-keys@3.4.3": true,
    "schema-utils@3.3.0": true,
    "schema-utils@4.3.3": true,
    "schema-utils@1.0.0": true,
    "entities@2.2.0": true,
    "entities@6.0.1": true,
    "minipass@7.1.3": true,
    "magic-string@0.25.9": true
  },
  "packageManager": "npm@10.8.2"
}
