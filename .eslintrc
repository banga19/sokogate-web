{
    "parser": "vue-eslint-parser",
    "parserOptions": {
        "parser": "babel-eslint",
        "sourceType": "module",
        "ecmaVersion": 2020
    },
    "rules": {
        "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
        "no-console": ["warn", { "allow": ["warn", "error"] }],
        "prefer-const": "warn",
        "no-var": "warn",
        "eqeqeq": ["warn", "smart"],
        "no-trailing-spaces": "warn",
        "eol-last": ["warn", "always"]
    }
}
