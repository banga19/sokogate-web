# ============================================================================
# SOKOGATE BACKEND — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ── Comment Agent Required ─────────────────────────────────────────────────
# NVIDIA_API_KEY         (no default — primary AI for analysis, comment gen, and embeddings)
# CLAUDE_API_KEY        (no default — fallback AI for production-grade analysis & comment gen)
# SMTP_HOST / SMTP_USER / SMTP_PASS or SENDGRID_API_KEY  (required for email alerts)
#
# All other variables have sensible defaults for local development.
# ============================================================================

# ── Environment ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Comment Agent — NVIDIA AI (Primary for testing) ────────────────────────
# Get your free API key: https://build.nvidia.com/
# Primary AI engine: post analysis, comment generation, sourcing alerts, embeddings
# Free tier available — ideal for development and testing
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: model override (default: meta/llama-3.3-70b-instruct)
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ── Comment Agent — Claude AI (Production fallback) ────────────────────────
# Get your API key: https://console.anthropic.com/
# Fallback AI engine for production-grade analysis & comment generation
# Used automatically when NVIDIA is unavailable or rate-limited
# CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: model override (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Comment Agent — Rate Limiting (anti-ban rules) ────────────────────────
# Max comments/day per agent  (spec: 20-30, default: 25)
# COMMENT_AGENT_DAILY_LIMIT=25
# Min delay between comments in seconds  (spec: 3 min, default: 180)
# COMMENT_AGENT_MIN_DELAY=180
# Max delay between comments in seconds  (spec: 8 min, default: 480)
# COMMENT_AGENT_MAX_DELAY=480

# ── Comment Agent — Email (Sourcing Alerts) ────────────────────────────────
# Sourcing alerts are sent to info@sokogate.com.
# Choose EITHER SMTP (Nodemailer) OR SendGrid. Both are supported.
# In dev mode (no email configured), emails are logged to the console.

# Option A: SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Option B: SendGrid (alternative to SMTP)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=agent@sokogate.com

# ── PostgreSQL ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sokogate
DB_USER=sokogate
DB_PASSWORD=changeme

# ── Apify Scraper (Auto-Ingestion — Phase 3) ──────────────────────────────
# Get your API key: https://console.apify.com/ (Free tier: $5/mo credits)
# The Apify Facebook Post Scraper Actor (apify/facebook-posts-scraper)
# and LinkedIn Post Scraper Actor (curiosum/linkedin-post-scraper)
# automatically ingest buyer posts from social media groups.
# Then the Comment Agent pipeline analyzes each post.
APIFY_API_KEY=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override default Actor IDs
# APIFY_FACEBOOK_ACTOR=apify/facebook-posts-scraper
# APIFY_LINKEDIN_ACTOR=curiosum/linkedin-post-scraper

# ── Redis ──────────────────────────────────────────────────────────────────
# Used by: Comment Agent rate limiter, job queue, embedding cache, sessions
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── JWT Authentication ─────────────────────────────────────────────────────
JWT_SECRET=change-to-a-long-random-string-at-least-32-chars
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4500

# ── General Rate Limiting ──────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100

# ── Logging ────────────────────────────────────────────────────────────────
# LOG_LEVEL=info

# ── Sentry Error Tracking ──────────────────────────────────────────────────
# SENTRY_DSN=

# ── CSP Violation Reporting ────────────────────────────────────────────────
# CSP_REPORT_URI=https://your-report-uri.example.com

# ── Payment Gateways ───────────────────────────────────────────────────────
# FLUTTERWAVE_PUBLIC_KEY=
# FLUTTERWAVE_SECRET_KEY=
# PAYSTACK_PUBLIC_KEY=
# PAYSTACK_SECRET_KEY=
# STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=

# ── Aliyun OSS (File Storage) ──────────────────────────────────────────────
# OSS_REGION=oss-cn-hongkong
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=sokogate-com
# OSS_ENDPOINT=https://oss-sokogate-com.oss-cn-hongkong.aliyuncs.com

# ── Easemob IM (Customer Chat) ─────────────────────────────────────────────
# EASEMOB_APPKEY=1101220606096669#demo
# EASEMOB_CLIENT_ID=
# EASEMOB_CLIENT_SECRET=
