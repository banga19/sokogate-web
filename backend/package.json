{
  "name": "sokogate-api",
  "version": "1.0.0",
  "private": true,
  "description": "Sokogate B2B E-Commerce API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src/ tests/",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest tests/unit --forceExit --detectOpenHandles",
    "test:int": "jest tests/integration --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles && npm run test:badges",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:undo": "npx sequelize-cli db:seed:undo:all",
    "test:db:start": "docker compose -f docker-compose.test.yml up -d",
    "test:db:stop": "docker compose -f docker-compose.test.yml down",
    "test:db:reset": "docker compose -f docker-compose.test.yml down -v",
    "test:db:migrate": "npx dotenv-cli -e .env.test -- npx sequelize-cli db:migrate",
    "test:db:seed": "npx dotenv-cli -e .env.test -- npx sequelize-cli db:seed:all",
    "test:db:wait": "node -e \"setTimeout(() => process.exit(0), 3000)\"",
    "test:db:setup": "npm run test:db:start && npm run test:db:wait && npm run test:db:migrate && npm run test:db:seed",
    "test:integration": "npm run test:db:start && npm run test:db:wait && npm run test:db:migrate && npm run test:db:seed && npm test && npm run test:db:stop",
    "test:badges": "npx istanbul-badges-readme --coverageDir=./coverage --readmeDir=.."
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "istanbul-badges-readme": "^1.9.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./tests/setup.js"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "collectCoverage": true,
    "coverageDirectory": "./coverage",
    "coverageReporters": ["json-summary", "lcov", "clover"],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 20,
        "functions": 8,
        "lines": 40,
        "statements": 40
      }
    }
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": [
        "warn"
      ],
      "no-console": "off"
    }
  }
}
